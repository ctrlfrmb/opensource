    {
      "pid": 3, "iso_pid": 62467,
      "name": "Fuel System Status", "name_zh": "燃油系统状态",
      "_fix": "#9 — Removed incorrect Byte A bits 5-7 (were wrongly labelled as B2 status) and Byte B bits 5-7; Byte A = Fuel System 1 (bits 0-4 only), Byte B = Fuel System 2 (bits 0-4 only), bits 5-7 reserved in both bytes",
      "description": "Byte A = Fuel System 1 status, Byte B = Fuel System 2 status (or $00 if no second fuel system). Each byte bits 0-4 are state-encoded (only one bit active at a time). Bits 5-7 are reserved ($0).",
      "description_zh": "字节A=燃油系统1状态，字节B=燃油系统2状态(无第二系统时为$00)。每字节位0-4为状态编码(同时只有一位激活)。位5-7为保留($0)。",
      "type": "bitmap", "data_bytes": 2,
      "bits": [
        { "byte": "A", "bit": 0, "name": "Fuel System 1: Open loop — not yet satisfied", "name_zh": "燃油系统1:开环-未满足条件", "v0": "", "v1": "OL" },
        { "byte": "A", "bit": 1, "name": "Fuel System 1: Closed loop — using O2 feedback", "name_zh": "燃油系统1:闭环-使用氧传感器反馈", "v0": "", "v1": "CL" },
        { "byte": "A", "bit": 2, "name": "Fuel System 1: Open loop — driving conditions", "name_zh": "燃油系统1:开环-驾驶条件", "v0": "", "v1": "OL-Drive" },
        { "byte": "A", "bit": 3, "name": "Fuel System 1: Open loop — system fault", "name_zh": "燃油系统1:开环-系统故障", "v0": "", "v1": "OL-Fault" },
        { "byte": "A", "bit": 4, "name": "Fuel System 1: Closed loop — O2 sensor fault", "name_zh": "燃油系统1:闭环-氧传感器故障", "v0": "", "v1": "CL-Fault" },
        { "byte": "B", "bit": 0, "name": "Fuel System 2: Open loop — not yet satisfied", "name_zh": "燃油系统2:开环-未满足条件", "v0": "", "v1": "OL" },
        { "byte": "B", "bit": 1, "name": "Fuel System 2: Closed loop — using O2 feedback", "name_zh": "燃油系统2:闭环-使用氧传感器反馈", "v0": "", "v1": "CL" },
        { "byte": "B", "bit": 2, "name": "Fuel System 2: Open loop — driving conditions", "name_zh": "燃油系统2:开环-驾驶条件", "v0": "", "v1": "OL-Drive" },
        { "byte": "B", "bit": 3, "name": "Fuel System 2: Open loop — system fault", "name_zh": "燃油系统2:开环-系统故障", "v0": "", "v1": "OL-Fault" },
        { "byte": "B", "bit": 4, "name": "Fuel System 2: Closed loop — O2 sensor fault", "name_zh": "燃油系统2:闭环-氧传感器故障", "v0": "", "v1": "CL-Fault" }
      ]
