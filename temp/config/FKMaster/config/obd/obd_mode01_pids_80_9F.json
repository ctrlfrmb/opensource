    {
      "pid": 144, "iso_pid": 62608,
      "name": "WWH-OBD Vehicle OBD System Information", "name_zh": "WWH-OBD车辆OBD系统信息",
      "_fix": "Rewritten from standard table — 3 bytes: A=bit-mapped status, B,C=continuous MI counter",
      "description": "Byte A: bits 0-1=Display strategy (00=non-discriminatory, 01=discriminatory, 10=reserved, 11=N/A). Bits 2-5=Vehicle MI activation mode (0000=Off, 0001=On Demand, 0010=Short, 0011=Continuous, 1110=Error, 1111=N/A). Bit 6=Emission system readiness (0=complete, 1=not complete). Bit 7=reserved. Bytes B,C=Continuous MI counter (1h/bit).",
      "description_zh": "字节A：位0-1=显示策略(00=非歧视性, 01=歧视性, 10=保留, 11=不可用)。位2-5=车辆MI激活模式(0000=关, 0001=按需, 0010=短暂, 0011=持续, 1110=错误, 1111=不可用)。位6=排放系统就绪(0=完成, 1=未完成)。位7=保留。字节B,C=持续MI计数器(1h/位)。",
      "type": "bitmap", "data_bytes": 3,
      "numeric_fields": [
        { "label": "MI_DISP_VOBD", "bytes": "A", "formula": "A & 3", "unit": "", "min": 0, "max": 3,
          "name": "MI Display Strategy", "name_zh": "MI显示策略",
          "_values": { "0": "Non-discriminatory", "1": "Discriminatory", "2": "Reserved", "3": "N/A" } },
        { "label": "MI_MODE_VOBD", "bytes": "A", "formula": "(A >> 2) & 15", "unit": "", "min": 0, "max": 15,
          "name": "Vehicle MI Activation Mode", "name_zh": "车辆MI激活模式",
          "_values": { "0": "Mode 1 (MI Off)", "1": "Mode 2 (On Demand)", "2": "Mode 3 (Short)", "3": "Mode 4 (Continuous)", "14": "Error", "15": "N/A" } },
        { "label": "VOBD_MI_TIME", "bytes": "B,C", "formula": "256 * B + C", "unit": "h", "min": 0, "max": 65535,
          "name": "Continuous MI Counter", "name_zh": "持续MI计数器" }
      ],
      "bits": [
        { "byte": "A", "bit": 6, "name": "Emission system readiness", "name_zh": "排放系统就绪", "v0": "All monitors complete", "v1": "Not complete" }
      ]
    },
    {
      "pid": 145, "iso_pid": 62609,
      "name": "WWH-OBD ECU OBD System Information", "name_zh": "WWH-OBD ECU OBD系统信息",
      "_fix": "Rewritten from standard table — 5 bytes: A=ECU MI mode, B,C=MI counter, D,E=B1 counter",
      "description": "Byte A: bits 0-3=ECU MI Activation Mode (same encoding as PID $90). Bits 4-7=reserved. Bytes B,C=ECU Continuous MI counter (1h/bit). Bytes D,E=Highest ECU B1 counter (1h/bit). For WWH-OBD, PID $01 Data A shall be $00.",
      "description_zh": "字节A：位0-3=ECU MI激活模式(同PID $90编码)。位4-7=保留。字节B,C=ECU持续MI计数器(1h/位)。字节D,E=最高ECU B1计数器(1h/位)。WWH-OBD时PID $01的字节A应为$00。",
      "type": "bitmap", "data_bytes": 5,
